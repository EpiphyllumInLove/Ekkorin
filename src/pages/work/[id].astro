---
import Layout from '../../layouts/Layout.astro';
import { works } from '../../data/works';

export async function getStaticPaths() {
  return works.map((work) => ({
    params: { id: work.id },
    props: { work },
  }));
}

const { work } = Astro.props;

// 多图支持：如果有 images 字段则使用，否则用单张 image
const images: string[] = work.images && work.images.length > 0 ? work.images : [work.image];
---

<Layout title={`${work.title} - Ekkorin Gallery`} description={work.title}>
  <nav class="back-nav">
    <a href="/" class="back-link">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      返回画廊
    </a>
  </nav>

  <main class="detail-page">
    <div class="images-section">
      {images.map((src) => (
        <div class="image-wrapper">
          <img src={src} alt={work.title} class="detail-image" />
        </div>
      ))}
    </div>

    <div class="info-bar">
      <h1 class="detail-title">{work.title}</h1>
      {work.bilibili && (
        <a href={`https://t.bilibili.com/${work.bilibili}`} target="_blank" rel="noopener" class="bili-btn">
          <svg class="bili-icon" viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
            <path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.662.373-.92.249-.258.555-.387.92-.387.364 0 .67.129.92.387L9.653 4.76c.142.142.213.32.213.533 0 .214-.071.392-.213.534-.143.142-.32.213-.534.213H5.333c-.924 0-1.71.338-2.36 1.013-.649.676-.979 1.458-.986 2.347v7.36c.007.889.337 1.67.986 2.347.65.675 1.436 1.013 2.36 1.013h13.334c.924 0 1.71-.338 2.36-1.013.65-.676.979-1.458.986-2.347v-7.36c-.007-.889-.337-1.67-.986-2.347-.65-.675-1.436-1.013-2.36-1.013H9.333c-.213 0-.391-.071-.533-.213-.143-.142-.214-.32-.214-.534 0-.213.071-.391.214-.533L12.107.907c.249-.258.555-.387.92-.387.364 0 .67.129.92.387.249.258.373.564.373.92 0 .355-.124.662-.373.906l-1.174 1.12h4.04zM8.107 10.64c.249-.258.555-.387.92-.387.364 0 .67.129.92.387.249.258.373.564.373.92v2.133c0 .355-.124.662-.373.92-.25.258-.556.387-.92.387-.365 0-.671-.129-.92-.387-.249-.258-.373-.565-.373-.92V11.56c0-.356.124-.662.373-.92zm5.866 0c.25-.258.556-.387.92-.387s.671.129.92.387c.249.258.373.564.373.92v2.133c0 .355-.124.662-.373.92-.249.258-.556.387-.92.387s-.671-.129-.92-.387c-.249-.258-.373-.565-.373-.92V11.56c0-.356.124-.662.373-.92z"/>
          </svg>
          在B站查看动态 ↗
        </a>
      )}
    </div>
  </main>
</Layout>

<style is:global>
  .back-nav {
    padding: 20px 24px 0;
    max-width: 1400px;
    margin: 0 auto;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-dim);
    font-size: 0.9rem;
    transition: color var(--transition);
    padding: 8px 16px;
    border-radius: 50px;
    background: var(--bg-card);
    border: 1px solid var(--border);
  }

  .back-link:hover {
    color: var(--text);
    border-color: var(--accent);
  }

  .detail-page {
    max-width: 1400px;
    margin: 0 auto;
    padding: 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .images-section {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }

  .image-wrapper {
    width: 100%;
    display: flex;
    justify-content: center;
    background: var(--bg-card);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .detail-image {
    display: block;
    max-width: 100%;
    max-height: 85vh;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .info-bar {
    width: 100%;
    max-width: 900px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .detail-title {
    font-size: 1.5rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .bili-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #00a1d6;
    color: #fff;
    padding: 10px 20px;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.2s;
    white-space: nowrap;
  }

  .bili-btn:hover {
    background: #33b4de;
  }

  .bili-icon {
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .detail-page {
      padding: 16px;
      gap: 16px;
    }

    .detail-title {
      font-size: 1.2rem;
    }

    .info-bar {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
